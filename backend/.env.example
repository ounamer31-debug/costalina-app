# Copy this file to .env and fill in real values. Never commit .env to git.

# MongoDB connection string. For local dev, this is typically:
#   mongodb://127.0.0.1:27017/costalina
# For MongoDB Atlas:
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/costalina
MONGODB_URI=mongodb://127.0.0.1:27017/costalina

# JWT signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 64+ random bytes recommended.
JWT_SECRET=change_me_to_a_long_random_string

# HTTP port (defaults to 3000 if omitted)
PORT=3000

# Comma-separated list of origins allowed to call the API.
# Leave empty (or omit) to allow everything — fine for dev, do not do this in prod.
#   CORS_ORIGINS=https://app.costalina.tn,https://admin.costalina.tn
CORS_ORIGINS=

# SMTP credentials for sending the password-reset OTP email.
# If unset, the OTP is logged to the server console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=